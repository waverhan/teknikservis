// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ServiceStatus {
  NEW
  IN_PROGRESS
  COMPLETED
}

enum UserRole {
  ADMIN
  TECHNICIAN
}

model Business {
  id                String           @id @default(cuid())
  email             String           @unique
  hashedPassword    String
  name              String
  phone             String?
  address           String?
  logo              String?
  slug              String           @unique
  customDomain     String?          @unique
  domainVerified   Boolean          @default(false)
  isPublic         Boolean          @default(true)
  primaryColor     String?          @default("#3B82F6")
  coverImage       String?
  publicDescription String?
  googleMapsUrl     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  users             User[]
  customers         Customer[]
  serviceRequests   ServiceRequest[]
  receipts          Receipt[]
  services          OfferedService[]
  reviews           Review[]
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  hashedPassword String
  name            String
  role            UserRole         @default(TECHNICIAN)
  businessId      String
  business        Business         @relation(fields: [businessId], references: [id])
  assignedJobs    ServiceRequest[] @relation("TechnicianJobs")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([businessId])
}

model Customer {
  id              String           @id @default(cuid())
  name            String
  phone           String
  email           String?
  address         String?
  businessId      String
  business        Business         @relation(fields: [businessId], references: [id])
  serviceRequests ServiceRequest[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([businessId])
}

model ServiceRequest {
  id          String   @id @default(cuid())
  description String
  notes       String?
  deviceBrand String?
  deviceModel String?
  status      ServiceStatus @default(NEW)
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  technicianId String?
  technician   User?    @relation("TechnicianJobs", fields: [technicianId], references: [id])
  actions     ServiceAction[]
  receipt     Receipt?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([customerId])
  @@index([technicianId])
}

model ServiceAction {
  id               String         @id @default(cuid())
  description      String
  price            Decimal        @db.Decimal(10, 2)
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([serviceRequestId])
}

model Receipt {
  id               String         @id @default(cuid())
  price            Decimal        @db.Decimal(10, 2)
  businessId       String
  business         Business       @relation(fields: [businessId], references: [id])
  serviceRequestId String         @unique
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([businessId])
}

model OfferedService {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal? @db.Decimal(10, 2)
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
}

model Review {
  id          String   @id @default(cuid())
  rating      Int      // 1-5
  comment     String?
  customerName String
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
}
